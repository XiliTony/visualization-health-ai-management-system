<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.noitidart.api.mapper.DashboardMapper">
    <select id="staticCount" resultType="com.noitidart.api.pojo.vo.StaticCountVO">
        SELECT
                (SELECT COUNT(*) FROM user) AS userCount,
                (SELECT COUNT(*) FROM health_item) AS itemCount;
    </select>
</mapper>